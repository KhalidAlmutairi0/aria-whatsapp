# OpenRouter — free Qwen (get key at openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Free Qwen models on OpenRouter:
# qwen/qwen2.5-72b-instruct:free  ← best quality, free
# qwen/qwen-2.5-7b-instruct:free  ← faster, free
QWEN_MODEL=qwen/qwen2.5-72b-instruct:free

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Server (Railway sets PORT automatically — don't change)
PORT=3000

# Location for prayer times (default: Riyadh)
LATITUDE=24.6877
LONGITUDE=46.7219
TIMEZONE=Asia/Riyadh
